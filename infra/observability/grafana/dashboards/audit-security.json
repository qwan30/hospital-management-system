{
  "uid": "hms-audit-security",
  "title": "HMS Audit And Security",
  "schemaVersion": 39,
  "refresh": "10s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Authorization Denials",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum by (status, reason) (rate(hms_security_authorization_denials_total[5m]))" }],
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 }
    },
    {
      "type": "timeseries",
      "title": "Rate Limit Rejections",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(rate(hms_security_rate_limit_rejections_total[5m]))" }],
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 }
    }
  ]
}
