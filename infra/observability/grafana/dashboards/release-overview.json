{
  "uid": "hms-release-overview",
  "title": "HMS Release Overview",
  "schemaVersion": 39,
  "refresh": "10s",
  "panels": [
    {
      "type": "stat",
      "title": "Backend Target",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "up{job=\"hms-backend\"}" }],
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 }
    },
    {
      "type": "timeseries",
      "title": "HTTP Requests",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(rate(hms_http_server_requests_seconds_count[5m]))" }],
      "gridPos": { "x": 6, "y": 0, "w": 10, "h": 8 }
    },
    {
      "type": "logs",
      "title": "Release Logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{ "expr": "{service=\"backend\"}" }],
      "gridPos": { "x": 0, "y": 8, "w": 16, "h": 8 }
    }
  ]
}
